# Gemini API key (https://aistudio.google.com/apikey).
# Usata per: chiamate ai 2 agenti, al giudice, e per Google Search grounding.
VITE_GEMINI_API_KEY=

# Modello Gemini (default: gemini-2.0-flash). Override solo se sai cosa fai.
VITE_GEMINI_MODEL=gemini-2.0-flash

# Modalita debug (true = log verbose in console, false = compatto).
VITE_DEBUG=true
